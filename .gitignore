# BI exports — regenerable from data/synthetic/. Keep the README + DAX + manifest only.
data/powerbi/*.parquet
data/powerbi/*.csv
data/tableau/*.csv

# ML artifacts — model registry + experiment tracking. Keep README only.
data/models/v*/
data/models/LATEST
mlruns/

# Tableau Hyper API runtime log
hyperd.log
data/tableau/_hyper/

# Pre-stage placeholders so empty dirs survive
!data/synthetic/.gitkeep
!data/reports/.gitkeep
